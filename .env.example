# ================================
# Database (SQLite)
# ================================
# Path al file SQLite. In Docker: file:/app/data/rrapp.db
DATABASE_URL=file:./data/rrapp.db

# ================================
# Backend
# ================================
# Genera con: openssl rand -base64 64  (mínimo 32 caracteres)
JWT_SECRET=change_me_generate_with_openssl_rand_base64_64
PORT=3000
NODE_ENV=production

# ================================
# Frontend (build-time)
# ================================
# En prod con nginx proxy: /api  | En dev: http://localhost:3000/api
VITE_API_URL=/api

# ================================
# Email (SMTP) — usar provider real en prod (Resend, Postmark, SendGrid)
# ================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=change_me
SMTP_FROM=noreply@yourdomain.com

# ================================
# CORS — dominios permitidos (separados por coma)
# ================================
FRONTEND_URL=https://yourdomain.com
